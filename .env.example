# ---- Server ----
PORT=3000
LOG_LEVEL=info

# ---- MongoDB (required) ----
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=github-trend

# ---- GitHub (required) ----
GITHUB_API_TOKEN=

# ---- AI provider: openai | deepseek ----
AI_PROVIDER=openai
# openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# deepseek / LM Studio (OpenAI-compatible local server)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_LOCAL_MODULE_NAME=

# ---- Fetch scheduling (cron, 6-field robfig format: sec min hour dom mon dow) ----
FETCH_CRON=0 30 3 * * *
CATEGORIZE_CRON=0 0 5 * * *
RATE_LIMIT_BUFFER=200
CATEGORIZE_BATCH_SIZE=15

# ---- Classification pipeline (change 9) ----
# Embedding tier: set EMBED_MODEL empty to disable; needs OPENAI_API_KEY (openai)
# or an LM Studio embedding model (deepseek).
EMBED_MODEL=text-embedding-3-small
EMBED_SIM_THRESHOLD=0.35

# ---- Google OAuth (added by the authentication change) ----
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
# JWT_SECRET=
# ADMIN_EMAILS=you@example.com
