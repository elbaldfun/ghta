# ---- Server ----
PORT=3000
LOG_LEVEL=info

# ---- MongoDB (required) ----
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=github-trend

# ---- GitHub (required) ----
GITHUB_API_TOKEN=

# ---- AI provider: openai | deepseek ----
AI_PROVIDER=openai
# openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# deepseek / LM Studio (OpenAI-compatible local server)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_LOCAL_MODULE_NAME=

# ---- Fetch scheduling (cron, 6-field robfig format: sec min hour dom mon dow) ----
FETCH_CRON=0 30 3 * * *
CATEGORIZE_CRON=0 0 5 * * *
RATE_LIMIT_BUFFER=200
CATEGORIZE_BATCH_SIZE=15

# ---- Classification pipeline (change 12) ----
# Two tiers: topic-map rules (free) -> LLM (long tail). The old embedding
# classification tier was dropped (eval: ~31% accuracy, below the LLM).
# DOMAIN_MAX_LABELS caps how many domain paths one item can carry (multi-label).
DOMAIN_MAX_LABELS=3
# Backend for the LLM tier: point AI_PROVIDER=deepseek at any OpenAI-compatible
# endpoint. For a hosted relay/xAI-Grok, set the base URL, model and a key:
#   AI_PROVIDER=deepseek
#   LMSTUDIO_BASE_URL=https://api.x.ai/v1   (or your relay)
#   LMSTUDIO_LOCAL_MODULE_NAME=grok-4.5
#   OPENAI_API_KEY=<relay/xai key>          (base-url path now sends it)

# EMBED_* is retained only for a future semantic-search change, unused by
# classification. Leave EMBED_MODEL empty unless you build that.
EMBED_MODEL=
EMBED_SIM_THRESHOLD=0.35

# ---- Google OAuth (added by the authentication change) ----
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
# JWT_SECRET=
# ADMIN_EMAILS=you@example.com
