# Copy to deploy/.env ON THE SERVER and fill in. Never commit the real file.
# Generate the two tokens with: openssl rand -hex 32

MONGO_ROOT_USER=ghta
MONGO_ROOT_PASSWORD=
# Guards /internal/*, /category and /user. Empty = those routes return 503.
ADMIN_API_TOKEN=
GITHUB_API_TOKEN=

# Only needed if AI categorization is enabled.
AI_PROVIDER=openai
OPENAI_API_KEY=
